  "datasets": [
    {
      "name": "74510824",
      "displayName": "Server Revenue Summary by Staff",
      "queryLines": [
        "SELECT server_name, SUM(total_revenue) as sales_performance\n",
        "FROM gold_restaurant.fact_sales\n",
        "GROUP BY server_name"
      ]
    },
    {
      "name": "f6a1233a",
      "displayName": "fact_sales",
      "queryLines": [
        "SELECT * FROM workspace.gold_restaurant.fact_sales"
      ]
    },
    {
      "name": "5c75cb00",
      "displayName": "Item Category Sales Summary",
