{
  "datasets": [
    {
      "name": "13169c52",
      "displayName": "Hourly Sales by Time",
      "queryLines": [
        "SELECT\n",
        "  t.hour,\n",
        "  SUM(f.total_amount) as total_sales\n",
        "FROM\n",
        "  workspace.gold_restaurant.fact_sales f\n",
        "    JOIN workspace.gold_restaurant.dim_time t\n",
        "      ON f.time_id = t.time_id\n",
        "GROUP BY\n",
        "  t.hour\n",
        "ORDER BY\n",
        "  t.hour"
      ]
    },
    {
      "name": "4a29c9e9",
      "displayName": "dim_emp",
      "queryLines": [
        "SELECT * FROM workspace.gold_restaurant.dim_emp"
      ]
    },
