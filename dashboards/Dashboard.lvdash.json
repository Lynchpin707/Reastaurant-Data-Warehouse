      ]
    },
    {
      "name": "f83f1d4c",
      "displayName": "fact_sales",
      "queryLines": [
        "SELECT * FROM workspace.gold_restaurant.fact_sales"
      ]
    },
    {
      "name": "a95d7d3c",
      "displayName": "Top 5 Menu Item Sales",
      "queryLines": [
        "SELECT \n",
        "  m.name, \n",
        "  COUNT(f.order_id) AS total_orders\n",
        "FROM \n",
        "  workspace.gold_restaurant.fact_sales f\n",
        "JOIN \n",
        "  workspace.gold_restaurant.dim_menu m ON f.item_id = m.item_id\n",
        "JOIN \n",
        "  workspace.gold_restaurant.dim_date d ON f.date_id = d.date_id\n",
        "WHERE \n",
        "  date_format(d.full_date, 'yyyy-MM-01') = :SelectedMonth \n",
        "GROUP BY \n",
        "  m.name\n",
        "ORDER BY \n",
        "  total_orders DESC\n",
        "LIMIT 5;"
      ],
      "parameters": [
        {
          "displayName": "SelectedMonth",
          "keyword": "SelectedMonth",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-12-01T00:00:00.000"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "b75b0e1c",
      "displayName": "High-level KPIs",
      "queryLines": [
        "SELECT \n",
        "  SUM(total_amount) AS total_revenue,\n",
        "  COUNT(DISTINCT order_id) AS total_orders,\n",
        "  SUM(total_amount) / COUNT(DISTINCT order_id) AS avg_order_value\n",
        "FROM workspace.gold_restaurant.fact_sales;"
      ]
    },
    {
      "name": "65e56929",
      "displayName": "Revenue by time of the day",
      "queryLines": [
        "SELECT \n",
        "  t.day_time,\n",
        "  SUM(s.total_amount) AS revenue\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_time t ON s.time_id = t.time_id\n",
        "GROUP BY 1\n",
        "ORDER BY revenue DESC;"
      ]
    },
    {
      "name": "50d420df",
      "displayName": "Sales per weather",
      "queryLines": [
        "SELECT \n",
        "  w.condition,\n",
        "  SUM(s.total_amount) AS total_sales,\n",
        "  AVG(s.qty) AS avg_items_per_order,\n",
        "  COUNT(order_id) AS number_of_orders\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_weather w ON s.weather_id = w.weather_id\n",
        "where order_type = 'delivery'\n",
        "GROUP BY 1\n",
        "ORDER BY total_sales DESC\n",
        "LIMIT 3;"
      ]
    },
    {
      "name": "208d0938",
      "displayName": "Top_1_waiters",
      "queryLines": [
        "SELECT \n",
        "  e.name  AS server_name,\n",
        "  SUM(s.total_amount) AS total_generated_revenue\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_emp e ON s.server_id = e.emp_id\n",
        "GROUP BY 1\n",
        "ORDER BY total_generated_revenue DESC\n",
        "LIMIT 1; "
      ]
    },
    {
      "name": "50ed4533",
      "displayName": "Peak Hours heatmap",
      "queryLines": [
        "SELECT \n",
        "  d.day_name_of_week,\n",
        "  t.hour,\n",
        "  COUNT(DISTINCT s.order_id) AS order_count\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_date d ON s.date_id = d.date_id\n",
        "JOIN workspace.gold_restaurant.dim_time t ON s.time_id = t.time_id\n",
        "GROUP BY 1, 2\n",
        "ORDER BY d.day_name_of_week, t.hour;"
      ]
    },
    {
      "name": "dd4b3f73",
      "displayName": "Top_10_selling_items",
      "queryLines": [
        "SELECT \n",
        "  m.name,\n",
        "  SUM(s.qty) AS total_quantity_sold\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_menu m ON s.item_id = m.item_id\n",
        "GROUP BY 1\n",
        "ORDER BY total_quantity_sold DESC\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "57fa2d16",
      "displayName": "weekend_vs_weekday",
      "queryLines": [
        "SELECT \n",
        "  m.name,\n",
        "  d.is_weekend,\n",
        "  SUM(s.qty) AS total_qty\n",
        "FROM workspace.gold_restaurant.fact_sales s\n",
        "JOIN workspace.gold_restaurant.dim_date d ON s.date_id = d.date_id\n",
        "JOIN workspace.gold_restaurant.dim_menu m ON s.item_id = m.item_id\n",
        "GROUP BY 1, 2\n",
        "ORDER BY total_qty DESC;"
      ]
    },
    {
      "name": "50918a80",
      "displayName": "Month picker",
      "queryLines": [
        "SELECT DISTINCT \n",
        "  date_format(full_date, 'MMMM yyyy') AS month_label,\n",
        "  date_format(full_date, 'yyyy-MM-01') AS month_value\n",
        "FROM workspace.gold_restaurant.dim_date\n",
        "ORDER BY month_value DESC;"
      ]
    }
  ],
